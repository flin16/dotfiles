#!/bin/bash
# setproxy — set/unset http_proxy/https_proxy, remembers last port
# Usage:  . setproxy [port]   or   source setproxy [port]
#         setproxy           — use saved port
#         setproxy 7892      — set to port 7892
#         setproxy off       — unset

CACHE="$HOME/.cache/proxy_port"
mkdir -p "$(dirname "$CACHE")"

case "${1:-}" in
  off)
    unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY all_proxy ALL_PROXY
    echo "proxy: unset"
    return 0
    ;;
  "")
    if [[ -f "$CACHE" ]]; then
      PORT=$(cat "$CACHE")
    else
      echo "proxy: no saved port"
      return 1
    fi
    ;;
  *)
    PORT="$1"
    echo "$PORT" > "$CACHE"
    ;;
esac

export http_proxy="http://127.0.0.1:$PORT"
export https_proxy="http://127.0.0.1:$PORT"
export HTTP_PROXY="http://127.0.0.1:$PORT"
export HTTPS_PROXY="http://127.0.0.1:$PORT"
export all_proxy="socks5h://127.0.0.1:$PORT"
export ALL_PROXY="socks5h://127.0.0.1:$PORT"
echo "proxy: set to port $PORT"
