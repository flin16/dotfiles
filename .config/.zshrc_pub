export PATH="$PATH:$HOME/go/bin:$HOME/bin:$HOME/.local/bin:$HOME/.elan/bin"
export EDITOR=nvim

plugins=(zsh-completions python fzf z per-directory-history)

alias ff=fastfetch
alias ly='lazygit -ucd ~/.local/share/yadm/lazygit -w ~ -g ~/.local/share/yadm/repo.git'
alias dc='docker-compose'


KEY_PATH="$HOME/.config/.keys"
if [ -f $KEY_PATH ]; then
    source $KEY_PATH
    export $(grep -v '^#' $KEY_PATH | grep '=' | awk -F= '{print $1}')
fi

# Check if the ssh-agent socket exists in the XDG_RUNTIME_DIR
# On archlinux use systemctl --user start ssh-agent.service to start it
if [[ -S "$XDG_RUNTIME_DIR/ssh-agent.socket" ]]; then
    export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"
fi

FPATH=~/.local/share/zsh/site-functions:$FPATH

venv() {
    if [ -z "$1" ]; then
        ls ~/venv/
        return
    fi

    local target="$HOME/venv/$1"
    if [ -d "$target" ]; then
        deactivate 2>/dev/null
        source "$target/bin/activate"
        echo "✅ Switched to virtualenv: $1"
    else
        echo "❌ Virtualenv not found: $target"
    fi
}

_venv_completions() {
    local cur=${COMP_WORDS[COMP_CWORD]}
    COMPREPLY=( $(compgen -W "$(ls ~/venv/)" -- "$cur") )
}

complete -F _venv_completions venv

if [[ "$(uname)" == "Darwin" ]]; then
  FZF_PATH="/opt/homebrew/opt/fzf/shell/"
else
  FZF_PATH="/usr/share/fzf"
fi

source "$FZF_PATH/key-bindings.zsh"
source "$FZF_PATH/completion.zsh"

eval "$(zoxide init zsh)"

# Mirror auto-detect for China (lazy — only re-check when cache is 6+ hours old)
_cache_file=/tmp/.china_mirror_cache
if [[ ! -f $_cache_file ]] || [[ $(find $_cache_file -mmin +360) ]]; then
  (curl -sI --connect-timeout 1 https://www.google.com >/dev/null 2>&1 && echo 0 || echo 1) > $_cache_file &!
fi
if [[ -f $_cache_file ]] && [[ $(cat $_cache_file) == "1" ]]; then
  export UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
  export HOMEBREW_API_DOMAIN=https://mirrors.tuna.tsinghua.edu.cn/homebrew-bottles/api
  export HOMEBREW_BOTTLE_DOMAIN=https://mirrors.tuna.tsinghua.edu.cn/homebrew-bottles
  export HOMEBREW_BREW_GIT_REMOTE=https://mirrors.tuna.tsinghua.edu.cn/git/homebrew/brew.git
  export HOMEBREW_CORE_GIT_REMOTE=https://git.homebrew/homebrew-core.git
  export HOMEBREW_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
fi
unset _cache_file

# Proxy switcher: proxy <port>, proxy, proxy off
proxy() {
  local output
  output=$(command proxy "$@")
  local ret=$?
  if [[ $ret -ne 0 ]]; then
    echo "No saved proxy port. Usage: proxy <port>"
    return 1
  fi
  if [[ "$1" == "off" ]]; then
    eval "$output"
    echo "proxy disabled"
  else
    eval "$output"
    echo "→ proxy 127.0.0.1:$(cat "$HOME/.cache/proxy_port" 2>/dev/null)"
  fi
}

bindkey '^T' transpose-chars
